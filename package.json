    "demo": "node agent.js --demo",
    "game": "electron overlay-window.js",
    "game:demo": "electron overlay-window.js --demo"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "irsdk-node": "*"
  },
  "devDependencies": {
    "electron": "^43.0.0"
  }
}
