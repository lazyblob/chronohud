{
  "name": "iracehud",
  "version": "0.1.0",
  "private": true,
  "description": "Trackmania-inspired iRacing telemetry HUD — local agent + transparent overlay",
  "license": "MIT",
  "keywords": [
    "iracing",
    "telemetry",
    "overlay",
    "hud",
    "sim-racing",
    "websocket",
    "irsdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "agent.js",
  "scripts": {
